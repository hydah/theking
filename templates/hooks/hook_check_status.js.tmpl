// theking hook: check that active task is at least in 'red' state before non-test code edits
// Usage: piped from Claude Code PreToolUse hook via stdin (JSON)
const fs = require('fs');
const path = require('path');

let data = '';
process.stdin.on('data', chunk => data += chunk);
process.stdin.on('end', () => {
  try {
    const input = JSON.parse(data);
    const filePath = input.tool_input?.file_path || '';

    // Allow editing test files, theking config, and claude config
    if (filePath.includes('.theking/') || filePath.includes('.claude/') || /test/i.test(filePath)) {
      process.stdout.write(data);
      return;
    }

    // Find .theking directory
    let dir = process.cwd();
    let thekingDir = null;
    for (let i = 0; i < 10; i++) {
      const candidate = path.join(dir, '.theking');
      if (fs.existsSync(candidate) && fs.statSync(candidate).isDirectory()) {
        thekingDir = candidate;
        break;
      }
      const parent = path.dirname(dir);
      if (parent === dir) break;
      dir = parent;
    }

    if (!thekingDir) {
      process.stdout.write(data);
      return;
    }

    const activeTaskFile = path.join(thekingDir, 'active-task');
    if (!fs.existsSync(activeTaskFile)) {
      process.stdout.write(data);
      return;
    }

    const taskDir = fs.readFileSync(activeTaskFile, 'utf-8').trim();
    const taskMdPath = path.join(taskDir, 'task.md');
    if (!fs.existsSync(taskMdPath)) {
      process.stderr.write('[theking] BLOCKED: active-task does not point to a valid task directory.\n');
      process.stderr.write(`[theking] Task: ${taskDir}\n`);
      process.exit(1);
    }

    const taskContent = fs.readFileSync(taskMdPath, 'utf-8');
    const statusMatch = taskContent.match(/^status:\s*(\S+)/m);
    const status = statusMatch ? statusMatch[1] : '';

    if (!status) {
      process.stderr.write('[theking] BLOCKED: task.md is missing a valid status field.\n');
      process.stderr.write(`[theking] Task: ${taskDir}\n`);
      process.exit(1);
    }

    const preRedStatuses = ['draft', 'planned'];
    if (preRedStatuses.includes(status)) {
      process.stderr.write(`[theking] BLOCKED: Task is in '${status}' state.\n`);
      process.stderr.write('[theking] Write tests first (move task to red) before writing implementation code.\n');
      process.stderr.write(`[theking] Task: ${taskDir}\n`);
      process.exit(1);
    }

    process.stdout.write(data);
  } catch (e) {
    process.stdout.write(data);
  }
});
