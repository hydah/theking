# Kimi Code CLI main agent for {project_slug} (theking governance)
#
# Load with: `kimi --agent-file .kimi/agent.yaml`
#
# This agent inherits Kimi's `default` tool policy so we do not need to keep a
# separate tool list in sync with upstream. Project-specific role behavior is
# carried by subagents that point back at canonical `.theking/agents/<role>.md`
# prompts — so editing a role's system prompt still happens in one place.
#
# This file is regenerated by `workflowctl ensure` / `workflowctl init-project`
# and can be overridden by the user: if the file already exists it will not be
# rewritten.

version: 1
agent:
  extend: default
  name: {main_agent_name}
  subagents:
{subagents_block}
